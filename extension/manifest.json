{
  "manifest_version": 3,
  "name": "ThreatAdvisor",
  "version": "1.0",
  "description": "Scan URLs for potential threats and security risks",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ThreatAdvisor - Check URL Safety"
  },
  "icons": {
    "16": "icons/image.png",
    "48": "icons/image.png",
    "128": "icons/image.png"
  }
}